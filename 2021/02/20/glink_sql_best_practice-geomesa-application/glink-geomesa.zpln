    {
      "text": "%flink.ssql(type\u003dupdate)\nSELECT A.id AS order_id, A.dtg, ST_AsText(ST_Point(A.lng, A.lat)) AS order_point, B.pid AS warehouse_id\n    FROM csv_order AS A\n    LEFT JOIN geomesa_warehouse FOR SYSTEM_TIME AS OF A.proctime AS B\n    ON ST_AsText(ST_Point(A.lng, A.lat)) \u003d B.geom",
      "user": "anonymous",
      "dateUpdated": "2022-06-08 21:01:17.370",
      "progress": 0,
