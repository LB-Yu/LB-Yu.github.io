      "results": {
        "code": "SUCCESS",
        "msg": [
          {
            "type": "HTML",
            "data": "\u003cdiv class\u003d\"markdown-body\"\u003e\n\u003ch1\u003eжЧґз©ЇжХ∞жНЃзЃ°йБУ \u0026amp; ETL\u003c/h1\u003e\n\u003cp\u003eжЬђж°ИдЊЛйАЪињЗGlinkжЙ©е±ХзЪДSQLе∞ЖCSVжЦЗдїґдЄ≠зЪДзВєжХ∞жНЃеѓЉеЕ•еИ∞GeoMesaдЄ≠.\u003c/p\u003e\n\u003col\u003e\n\u003cli\u003eеИЫеїЇдЄАдЄ™csvжЦЗдїґеЖЩеЕ•е¶ВдЄЛеЖЕеЃє, ињЩйЗМдЄЇжЉФз§ЇжЦєдЊњеП™дљњзФ®дЇЖ4жЭ°иЃ∞ељХ.\u003c/li\u003e\n\u003c/ol\u003e\n\u003cpre\u003e\u003ccode\u003e1,2008-02-02 13:30:40,116.31412,70.89454\n2,2008-02-02 13:30:44,116.31412,39.89454\n3,2008-02-02 13:30:45,116.32674,39.89577\n4,2008-02-02 13:30:49,116.31412,39.89454\n\u003c/code\u003e\u003c/pre\u003e\n\u003cp\u003ecsvжЦЗдїґеИЫеїЇеЃМжИРеРО, йАЪињЗе¶ВдЄЛиѓ≠еП•еЃЪдєЙ\u003ccode\u003ecsv_table\u003c/code\u003eдљЬдЄЇsource table, \u003cstrong\u003eж≥®жДП\u003ccode\u003epath\u003c/code\u003eеПВжХ∞зЪДеАЉйЬАи¶Бж†єжНЃcsvжЦЗдїґзЪДиЈѓеЊДдњЃжФє\u003c/strong\u003e.\u003c/p\u003e\n\n\u003c/div\u003e"
